#set modifies 
set $super Mod4
set $alt Mod1

#set font
fontpango: JetBrainsMono Font 10

#Use Mouse+$Super to drag floating window to their wanted position
floating_modifier $super

#Open basic Processes
bindsym $super+Shift+Return workspace 1, exec firefox
bindsym $super+Return workspace 2, exec kitty 
bindsym $super+Control+Return workspace 3, exec kitty -e nvim
bindsym $super+s workspace 4, exec LD_PRELOAD=/usr/local/lib/spotify-adblock.so spotify-launcher
bindsym $super+$alt+Return workspace 5, exec kitty -e yazi
bindsym $super+t workspace 10, exec kitty -e rtorrent

#wifi
bindsym $super+w exec wifi
#music
bindsym $super+m exec music

#start rofi
bindsym $super+d exec rofi -lines 12 -padding 18 -width 60 -location 0 -show drun 0 -sidebar-mode -columns 3

#kill focused window
bindsym $super+c kill

#change focus
bindsym $super+h focus left
bindsym $super+j focus down
bindsym $super+k focus up
bindsym $super+l focus right

#move focused window 
bindsym $super+Shift+h move left
bindsym $super+Shift+j move down
bindsym $super+Shift+k move up
bindsym $super+Shift+l move right

#split horizontal orientation
bindsym $super+p split h

#split vertical orientation
bindsym $super+v split v

#enter fullscreen mode for the focused container
bindsym $super+f fullscreen toggle

#change container layout
bindsym $super+shift+s layout toggle split

#toggle tiling/floating
bindsym $super+space floating toggle

#changing focus between tiling/floating
bindsym $super+Shift+space focus mode_toggle
for_window [floating] resize set 1000 500
floating_minimum_size 200 x 100
floating_maximum_size 1800 x 1000

#variable names for workspaces
#set $ws1 "1: "
#set $ws1 ""``
#set $ws1 ""
#set $ws1 ""
#set $ws1 ""
#set $ws1 ""

#switch to workspace
bindsym $super+Control+l workspace next
bindsym $super+Control+h workspace prev
bindsym $super+1 workspace 1
bindsym $super+2 workspace 2
bindsym $super+3 workspace 3
bindsym $super+4 workspace 4
bindsym $super+5 workspace 5
bindsym $super+6 workspace 6
bindsym $super+7 workspace 7
bindsym $super+8 workspace 8
bindsym $super+9 workspace 9
bindsym $super+0 workspace 10

#move focused container to workspace
bindsym $super+Shift+1 move container to workspace 1
bindsym $super+Shift+2 move container to workspace 2
bindsym $super+Shift+3 move container to workspace 3
bindsym $super+Shift+4 move container to workspace 4
bindsym $super+Shift+5 move container to workspace 5
bindsym $super+Shift+6 move container to workspace 6
bindsym $super+Shift+7 move container to workspace 7
bindsym $super+Shift+8 move container to workspace 8
bindsym $super+Shift+9 move container to workspace 9
bindsym $super+Shift+0 move container to workspace 10

#move focused container to workspace and switch
bindsym $super+Control+1 move container to workspace 1, workspace 1
bindsym $super+Control+2 move container to workspace 2, workspace 2
bindsym $super+Control+3 move container to workspace 3, workspace 3
bindsym $super+Control+4 move container to workspace 4, workspace 4
bindsym $super+Control+5 move container to workspace 5, workspace 5
bindsym $super+Control+6 move container to workspace 6, workspace 6
bindsym $super+Control+7 move container to workspace 7, workspace 7
bindsym $super+Control+8 move container to workspace 8, workspace 8
bindsym $super+Control+9 move container to workspace 9, workspace 9
bindsym $super+Control+0 move container to workspace 10, workspace 10

#restart i3 in place
bindsym $super+Shift+r restart

#exit
bindsym $super+q exec "i3-nagbar -t warning -m 'Really, exit?' -b 'Yes' 'i3-msg exit'"

#resize window
bindsym $super+$alt+h resize grow width 5 px or 5 ppt
bindsym $super+$alt+j resize shrink height 5 px or 5 ppt
bindsym $super+$alt+k resize grow height 5 px or 5 ppt
bindsym $super+$alt+l resize shrink width 5 px or 5 ppt


#panel
default_border normal

for_window [class="^.*"] border pixel 3
gaps inner 10
gaps outer 10

# Set colors from Xresources
# Change 'color7' and 'color2' to whatever colors you want i3 to use 
# from the generated scheme.
# NOTE: The '#f0f0f0' in the lines below is the color i3 will use if
# it fails to get colors from Xresources.
set_from_resource $fg i3wm.color7 #ffffff
set_from_resource $bg i3wm.color2 #ffffff

# class                 border  backgr. text indicator child_border
client.focused          #ffffff #ffffff #ffffff  #ffffff  #ffffff
#client.focused_inactive $bg     $bg     $fg  $bg       $bg
#client.unfocused        $bg     $bg     $fg  $bg       $bg
#client.urgent           $bg     $bg     $fg  $bg       $bg
#client.placeholder      $bg     $bg     $fg  $bg       $bg

client.background       $bg

set $wallpaper $HOME/Pictures/wallpapers/aesthetic-wallpapers/images/dark_pixelart.png

exec_always feh --bg-fill $wallpaper
exec_always wal -i $wallpaper
exec_always picom -b
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec_always playerctld daemon
exec_always xset b off
exec_always systemctl enable xampp.service
exec_always systemctl enable rtorrent
exec_always LD_PRELOAD=/usr/local/lib/spotify-adblock.so
exec_always pywal-spicetify text

#media player
bindsym XF86AudioRaiseVolume exec --no-startup-id media-control volume_up
bindsym XF86AudioLowerVolume exec --no-startup-id media-control volume_down
bindsym XF86AudioMute exec --no-startup-id media-control volume_mute
bindsym XF86MonBrightnessUp exec --no-startup-id media-control brightness_up
bindsym XF86MonBrightnessDown exec --no-startup-id media-control brightness_down
bindsym XF86AudioPlayPause exec --no-startup-id media-control play_pause
bindsym XF86AudioPause exec --no-startup-id media-control play_pause
bindsym XF86AudioPlay exec --no-startup-id media-control play_pause
bindsym XF86AudioNext exec --no-startup-id media-control next_track
bindsym XF86AudioPrev exec --no-startup-id media-control prev_track
bindsym XF86AudioMicMute exec --no-startup-id media-control mic_mute
bindsym XF86Calculator exec --no-startup-id betterlockscreen -l 
bindsym Print exec --no-startup-id screenshot
